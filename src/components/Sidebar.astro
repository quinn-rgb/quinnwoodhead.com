---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
};

const links = [
	{ href: '/', label: 'Home', num: '01' },
	{ href: '/about', label: 'About', num: '02' },
	{ href: '/projects', label: 'Projects', num: '03' },
	{ href: '/athletics', label: 'Athletics', num: '04' },
	{ href: '/art', label: 'Art', num: '05' },
	{ href: '/blog', label: 'Blog', num: '06' },
];
---

<button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
	<span></span><span></span><span></span>
</button>

<aside class="sidebar" id="sidebar">
	<div class="sidebar-top">
		<a class="brand" href="/">
			<span class="brand-name">{SITE_TITLE}</span>
		</a>
		<p class="brand-tag">Designer · Athlete · Builder</p>
	</div>

	<nav>
		<ul>
			{
				links.map((l) => (
					<li>
						<a href={l.href} class={isActive(l.href) ? 'active' : ''}>
							<span class="num">{l.num}</span>
							<span class="label">{l.label}</span>
						</a>
					</li>
				))
			}
		</ul>
	</nav>

	<div class="sidebar-bottom">
		<div class="wave"></div>
		<a href="mailto:qwoodhead@gmail.com" class="email">qwoodhead@gmail.com</a>
		<p class="copyright">© {new Date().getFullYear()}</p>
	</div>
</aside>

<script>
	const toggle = document.getElementById('menu-toggle');
	const sidebar = document.getElementById('sidebar');
	toggle?.addEventListener('click', (e) => {
		e.stopPropagation();
		sidebar?.classList.toggle('open');
		toggle.classList.toggle('open');
	});
	document.addEventListener('click', (e) => {
		if (
			sidebar?.classList.contains('open') &&
			!sidebar.contains(e.target as Node) &&
			!toggle?.contains(e.target as Node)
		) {
			sidebar.classList.remove('open');
			toggle?.classList.remove('open');
		}
	});
</script>

<style>
	.sidebar {
		position: fixed;
		top: 0;
		left: 0;
		width: 240px;
		height: 100vh;
		padding: 2.5em 1.75em;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-right: 1px solid rgba(0, 119, 182, 0.18);
		display: flex;
		flex-direction: column;
		z-index: 50;
		transition: transform 0.3s ease;
	}

	.sidebar-top {
		margin-bottom: 2.5em;
	}
	.brand {
		display: block;
		text-decoration: none;
		color: var(--ocean-deep);
	}
	.brand-name {
		display: block;
		font-size: 1.35em;
		font-weight: 700;
		line-height: 1.1;
		color: var(--ocean-deep);
	}
	.brand-tag {
		margin: 0.5em 0 0 0;
		font-size: 0.7em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
		font-weight: 600;
	}

	nav {
		flex: 1;
	}
	nav ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.15em;
	}
	nav a {
		display: flex;
		align-items: baseline;
		gap: 0.7em;
		padding: 0.6em 0.5em;
		text-decoration: none;
		color: var(--ocean-deep);
		font-size: 1em;
		border-radius: 6px;
		transition: all 0.15s ease;
	}
	nav a .num {
		font-size: 0.65em;
		font-weight: 700;
		color: var(--accent);
		opacity: 0.55;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.08em;
	}
	nav a .label {
		flex: 1;
	}
	nav a:hover {
		background: rgba(0, 180, 216, 0.1);
		color: var(--accent);
	}
	nav a.active {
		background: rgba(0, 119, 182, 0.12);
		color: var(--accent-dark);
		font-weight: 600;
	}
	nav a.active .num {
		opacity: 1;
	}

	.sidebar-bottom {
		margin-top: 2em;
	}
	.wave {
		height: 24px;
		margin-bottom: 1em;
		background:
			radial-gradient(circle at 15% 100%, transparent 12px, var(--accent-light) 13px 14px, transparent 15px),
			radial-gradient(circle at 50% 100%, transparent 12px, var(--accent-light) 13px 14px, transparent 15px),
			radial-gradient(circle at 85% 100%, transparent 12px, var(--accent-light) 13px 14px, transparent 15px);
		opacity: 0.5;
	}
	.email {
		display: block;
		font-size: 0.82em;
		color: var(--accent);
		text-decoration: none;
		word-break: break-all;
	}
	.email:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}
	.copyright {
		margin: 0.4em 0 0 0;
		font-size: 0.7em;
		color: rgb(var(--gray));
	}

	.menu-toggle {
		display: none;
		position: fixed;
		top: 1em;
		left: 1em;
		z-index: 100;
		width: 44px;
		height: 44px;
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(0, 119, 182, 0.2);
		border-radius: 8px;
		cursor: pointer;
		padding: 0;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		gap: 4px;
		backdrop-filter: blur(8px);
	}
	.menu-toggle span {
		display: block;
		width: 20px;
		height: 2px;
		background: var(--ocean-deep);
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.menu-toggle.open span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}
	.menu-toggle.open span:nth-child(2) {
		opacity: 0;
	}
	.menu-toggle.open span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	@media (max-width: 900px) {
		.sidebar {
			transform: translateX(-100%);
			box-shadow: 0 0 40px rgba(0, 0, 0, 0.15);
		}
		.sidebar.open {
			transform: translateX(0);
		}
		.menu-toggle {
			display: flex;
		}
	}
</style>
