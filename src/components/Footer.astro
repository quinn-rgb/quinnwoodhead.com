---
const today = new Date();
---

<footer>
	<div class="wave"></div>
	<p>&copy; {today.getFullYear()} Quinn Woodhead</p>
</footer>
<style>
	footer {
		padding: 0 0 3em 0;
		background: linear-gradient(180deg, #ffffff 0%, #ade8f4 100%);
		color: var(--ocean-deep);
		text-align: center;
	}
	footer p {
		margin: 0;
		padding: 1em;
		font-size: 0.95em;
	}
	.wave {
		height: 60px;
		background:
			radial-gradient(circle at 20% 100%, transparent 30px, #ade8f4 31px),
			radial-gradient(circle at 60% 100%, transparent 30px, #ade8f4 31px);
		background-size: 80px 60px;
		opacity: 0.8;
	}
</style>
